    <!-- xenotypes — curated visual descriptions for the {race} tag -->
    <!-- mod authors can add entries matching their XenotypeDef.defName -->
    <!-- Xenotype face descriptors. These are SUBSTITUTED into the {race}
         token of the prompt preamble at runtime by XenotypeDescriptionGenerator.
         For SDXL to actually deviate from a human face on non-human xenotypes
         (Yttakin, Pigskin, Impid), the prompt needs explicit "anthropomorphic"
         language and weighted critical features — SDXL is heavily biased
         toward human faces and will draw one unless strongly pulled away.

         Token weighting syntax: (text:1.3) tells SDXL to emphasize that text
         30% more than default. Use sparingly on the most distinctive features.
         The vanilla pretrained SDXL doesn't know what "Yttakin" or "Impid"
         means — it understands DESCRIPTION tokens, not RimWorld lore names.
         So describe the features, not the species name. -->

    <Avatar.AIGenPromptDef>
        <defName>Dirtmole</defName>
        <prompt>pale gray-tinted skin, broad compact face, squinting sensitive eyes, low-light adapted</prompt>
    </Avatar.AIGenPromptDef>

    <Avatar.AIGenPromptDef>
